{
  "name": "gifting-butler-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Mobile app wrapper for Gifting Butler.",
  "scripts": {
    "mobile:prepare": "powershell -ExecutionPolicy Bypass -File scripts/prepare-mobile.ps1",
    "mobile:assets": "capacitor-assets generate --ios --iconBackgroundColor \"#5B2D8E\" --iconBackgroundColorDark \"#2A1250\" --splashBackgroundColor \"#F0E8FB\" --splashBackgroundColorDark \"#2A1250\" && capacitor-assets generate --android --iconBackgroundColor \"#5B2D8E\" --iconBackgroundColorDark \"#2A1250\" --splashBackgroundColor \"#F0E8FB\" --splashBackgroundColorDark \"#2A1250\"",
    "mobile:sync": "npm run mobile:prepare && cap sync",
    "mobile:android": "npm run mobile:sync && cap open android",
    "mobile:ios": "npm run mobile:sync && cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/core": "^7.4.3",
    "@capacitor/ios": "^7.4.3"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.4.3"
  }
}
